using System;
namespace Classobject 
{
    class Students 
    {    
        public string? name;
        public string? age;
        public string? course;
        public string? number;
        public void Display()
        {
            Console.WriteLine("\nStudent " + number);
            Console.WriteLine("Name: " + name);
            Console.WriteLine("Age: " + age);
            Console.WriteLine("Course: " + course);
        } 
    }
 
    class StudentForm 
    {
        static void Main(string[] args) 
        {
            Students s1 = new Students();
            Console.Write("Student No. : ");
            s1.number = Console.ReadLine();
            Console.Write("Input Name: ");
            s1.name = Console.ReadLine();
            Console.Write("Input Age: ");
            s1.age = Console.ReadLine();
            Console.Write("Input Course: ");
            s1.course = Console.ReadLine();
            Students s2 = new Students();
            Console.Write("Student No. : ");
            s2.number = Console.ReadLine();
            Console.Write("Input Name: ");
            s2.name = Console.ReadLine();
            Console.Write("Input Age: ");
            s2.age = Console.ReadLine();
            Console.Write("Input Course: ");
            s2.course = Console.ReadLine();
            s1.Display();
            s2.Display();
        }
    }
}
